# Copy to .env and fill in. NEVER commit .env (it is git-ignored by the scaffold).
# These are required BEFORE the first full pipeline run — the pipeline fails fast
# with a clear message if any is missing.

# Google AI Studio key — used for image generation (Gemini 2.5 Flash Image /
# "Nano Banana", switchable to Imagen 4) and optionally for script generation.
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ElevenLabs — narration TTS.
# Get the key at: https://elevenlabs.io -> Profile -> API Keys
ELEVENLABS_API_KEY=

# The voice to narrate with (per-channel; channel.yaml references this).
# Pick/design a voice in the ElevenLabs Voice Library and paste its ID here.
# Target character (see TONE-OF-VOICE.md): warm, calm, mid-low male, conversational,
# relaxed bedtime energy, natural at ~145 wpm — NOT a dramatic movie-trailer voice.
ELEVENLABS_VOICE_ID=
